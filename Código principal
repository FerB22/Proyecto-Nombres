        panel_faccion = QFrame()
        panel_faccion.setObjectName("panel")
        layout_faccion = QVBoxLayout(panel_faccion)
        layout_faccion.setSpacing(15)

        lbl_tit_fac = QLabel("🏰 2. Asignar Comunidades")
        lbl_tit_fac.setObjectName("titulo_panel")
        
        form_faccion = QFormLayout()
        self.combo_region_faccion = QComboBox()
        self.combo_tipo_faccion = QComboBox()
        self.combo_tipo_faccion.addItems(["Reino", "Tribu"])
        self.input_nombre_faccion = QLineEdit()
        self.input_nombre_faccion.setPlaceholderText("Ej: Gremio de Hierro")
        
        form_faccion.addRow("Región:", self.combo_region_faccion)
        form_faccion.addRow("Tipo:", self.combo_tipo_faccion)
        form_faccion.addRow("Nombre:", self.input_nombre_faccion)
        
        btn_fac = QPushButton("Vincular Asentamiento")
        btn_fac.clicked.connect(self.guardar_faccion)

        layout_faccion.addWidget(lbl_tit_fac)
        layout_faccion.addLayout(form_faccion)
        layout_faccion.addSpacing(10)
        layout_faccion.addWidget(btn_fac)
        layout_faccion.addStretch()

        layout_principal.addWidget(panel_region, 1)
        layout_principal.addWidget(panel_faccion, 1)
        self.setLayout(layout_principal)
        
        self.actualizar_combos()

    def actualizar_combos(self):
        region_actual = self.combo_region_faccion.currentText()
        self.combo_region_faccion.clear()
        try:
            conexion = sqlite3.connect("lore.db")
            cursor = conexion.cursor()
            cursor.execute("SELECT id, nombre FROM regiones")
            regiones = cursor.fetchall()
            conexion.close()
            
            for region_id, nombre in regiones:
                self.combo_region_faccion.addItem(nombre, userData=region_id)
                
            if region_actual:
                self.combo_region_faccion.setCurrentText(region_actual)
        except sqlite3.Error:
            pass

    def guardar_region(self):
        nombre = self.input_nueva_region.text().strip()
        if not nombre:
            QMessageBox.warning(self, "Validación", "El nombre de la región no puede estar vacío.")
            return
        try:
            conexion = sqlite3.connect("lore.db")
            cursor = conexion.cursor()
            cursor.execute("INSERT INTO regiones (nombre) VALUES (?)", (nombre,))
            conexion.commit()
            conexion.close()
            
            QMessageBox.information(self, "Éxito", f"Región '{nombre}' guardada en el mapa.")
            self.input_nueva_region.clear()
            
            self.callback_sincronizar()
        except sqlite3.Error:
            QMessageBox.warning(self, "Error", "Esa región ya existe en la base de datos.")

    def guardar_faccion(self):
        region_id = self.combo_region_faccion.currentData()
        tipo = self.combo_tipo_faccion.currentText()
        nombre = self.input_nombre_faccion.text().strip()

        if not region_id or not nombre:
            QMessageBox.warning(self, "Validación", "Debes seleccionar una región y escribir un nombre.")
            return

        try:
            conexion = sqlite3.connect("lore.db")
            cursor = conexion.cursor()
            cursor.execute("INSERT INTO facciones (region_id, tipo, nombre) VALUES (?, ?, ?)", (region_id, tipo, nombre))
            conexion.commit()
            conexion.close()
            
            QMessageBox.information(self, "Éxito", f"{tipo} '{nombre}' anexado correctamente.")
            self.input_nombre_faccion.clear()
            self.callback_sincronizar()
        except sqlite3.Error as e:
            QMessageBox.critical(self, "Error SQL", str(e))


