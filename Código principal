        layout_der.addWidget(self.combo_region, alignment=Qt.AlignCenter)
        layout_der.addWidget(lbl_info_territorio)
        layout_der.addWidget(self.texto_facciones)
        layout_der.addWidget(lbl_silabas, alignment=Qt.AlignCenter)
        layout_der.addWidget(self.combo_silabas, alignment=Qt.AlignCenter)
        layout_der.addSpacing(5)
        layout_der.addWidget(btn_generar, alignment=Qt.AlignCenter)
        layout_der.addWidget(self.etiqueta_resultado)

        layout_principal.addWidget(panel_izq, 1)
        layout_principal.addWidget(panel_der, 2)
        self.setLayout(layout_principal)
        
        self.actualizar_combo_regiones()

    def actualizar_combo_regiones(self):
        region_actual = self.combo_region.currentText()
        self.combo_region.clear()
        morfologia = obtener_morfologia_db()
        if morfologia:
            self.combo_region.addItems(morfologia.keys())
            for region in morfologia.keys():
                if region not in self.historial_nombres:
                    self.historial_nombres[region] = []
            
            if region_actual in morfologia.keys():
                self.combo_region.setCurrentText(region_actual)
                
        self.cargar_facciones_territorio()

    def cargar_facciones_territorio(self):
        region = self.combo_region.currentText()
        if not region:
            self.texto_facciones.setPlainText("")
            return
        
        facciones = obtener_facciones_region(region)
        if not facciones:
            self.texto_facciones.setPlainText("Explorado: Territorio virgen (Sin reinos ni tribus registrados).")
            return
            
        texto = []
        reinos = [f[1] for f in facciones if f[0] == "Reino"]
        tribus = [f[1] for f in facciones if f[0] == "Tribu"]
        
        if reinos:
            texto.append("🏰 REINOS:")
            for r in reinos:
                texto.append(f"  • {r}")
        if tribus:
            if reinos: texto.append("") 
            texto.append("🔥 TRIBUS:")
            for t in tribus:
                texto.append(f"  • {t}")
                
        self.texto_facciones.setPlainText("\n".join(texto))

    def generar_nombre(self):
        region = self.combo_region.currentText()
        if not region: return

        morfologia = obtener_morfologia_db()
        reglas = morfologia.get(region, {})
        amount_silabas = int(self.combo_silabas.currentText())

        if not reglas.get("prefijos") or not reglas.get("sufijos"):
            self.etiqueta_resultado.setText("⚠️ Faltan morfemas en la BD")
            return

        prefijo = random.choice(reglas["prefijos"])
        sufijo = random.choice(reglas["sufijos"])

        if amount_silabas == 2:
            nombre_crudo = f"{prefijo}{sufijo}"
        elif amount_silabas == 3:
            if not reglas.get("raices"):
                self.etiqueta_resultado.setText("⚠️ Falta agregar raíces")
                return
            raiz = random.choice(reglas["raices"])
            nombre_crudo = f"{prefijo}{raiz}{sufijo}"
        else:
            if len(reglas.get("raices", [])) < 1:
                self.etiqueta_resultado.setText("⚠️ Requiere raíces")
                return
            raiz1 = random.choice(reglas["raices"])
            raiz2 = random.choice(reglas["raices"])
            nombre_crudo = f"{prefijo}{raiz1}{raiz2}{sufijo}"

        nombre_generado = nombre_crudo.lower().capitalize()
        self.etiqueta_resultado.setText(f"✨ {nombre_generado} ✨")

        if region in self.historial_nombres:
            self.historial_nombres[region].append(nombre_generado)

        texto = []
        for reg, nombres in self.historial_nombres.items():
            if nombres:
                texto.append(f"--- {reg} ---")
                for n in nombres:
                    texto.append(f"• {n}")
                texto.append("")

        self.texto_historial.setPlainText("\n".join(texto))


