    def crear_suite(self):
        layout_maestro = QVBoxLayout()
        layout_maestro.setContentsMargins(10, 10, 10, 10)

        self.pestanas = QTabWidget()

        # Instanciar paneles pasando el método central sincronizar_todo
        self.tab_generador = TabGenerador()
        self.tab_mundo = TabGestorMundo(self.sincronizar_todo)
        self.tab_morfemas = TabGestorMorfemas(self.sincronizar_todo)
        self.tab_editor = TabEditor(self.sincronizar_todo) # <-- Nueva Instancia

        self.pestanas.addTab(self.tab_generador, "🌌 Forja de Nombres")
        self.pestanas.addTab(self.tab_mundo, "🗺️ Panel de Mundo")
        self.pestanas.addTab(self.tab_morfemas, "🧬 Lingüística") 
        self.pestanas.addTab(self.tab_editor, "📝 Editor de Contenido") # <-- Nueva pestaña vinculada

        layout_maestro.addWidget(self.pestanas)
        self.setLayout(layout_maestro)

    def sincronizar_todo(self):
