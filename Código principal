        lbl_info_territorio.setObjectName("subtitulo")
        
        self.texto_facciones = QTextEdit()
        self.texto_facciones.setReadOnly(True)
        self.texto_facciones.setFixedHeight(100)
        self.texto_facciones.setPlaceholderText("No hay asentamientos registrados aquí.")

        lbl_silabas = QLabel("Longitud del nombre (Sílabas):")
        lbl_silabas.setAlignment(Qt.AlignCenter)
        lbl_silabas.setObjectName("subtitulo")

        self.combo_silabas = QComboBox()
        self.combo_silabas.addItems(["2", "3", "4"])
        self.combo_silabas.setCurrentText("3")
        self.combo_silabas.setFixedWidth(80)

        btn_generar = QPushButton("Forjar Nombre")
        btn_generar.setFixedHeight(40)
        btn_generar.clicked.connect(self.generar_nombre)

