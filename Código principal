        lbl_tit_reg = QLabel("🗺️ 1. Registrar Región")
        lbl_tit_reg.setObjectName("titulo_panel")
        
        form_region = QFormLayout()
        self.input_nueva_region = QLineEdit()
        self.input_nueva_region.setPlaceholderText("Ej: Continente Helado")
        form_region.addRow("Nueva Región:", self.input_nueva_region)
        
        btn_reg = QPushButton("Crear Región")
        btn_reg.clicked.connect(self.guardar_region)

        layout_region.addWidget(lbl_tit_reg)
        layout_region.addLayout(form_region)
        layout_region.addSpacing(10)
        layout_region.addWidget(btn_reg)
