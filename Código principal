# LÓGICA DE BASE DE DATOS (SQLITE)
# =====================================================================
def inicializar_y_actualizar_db():
    conexion = sqlite3.connect("lore.db")
    cursor = conexion.cursor()
    
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS regiones (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            nombre TEXT UNIQUE NOT NULL
        )
    """)
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS morfemas (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            region_id INTEGER,
            tipo TEXT NOT NULL, 
            valor TEXT NOT NULL,
            FOREIGN KEY (region_id) REFERENCES regiones (id)
        )
    """)
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS facciones (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            region_id INTEGER,
            tipo TEXT NOT NULL,
            nombre TEXT NOT NULL,
            FOREIGN KEY (region_id) REFERENCES regiones (id)
        )
    """)
    conexion.commit()
    conexion.close()


def obtener_morfologia_db():
    try:
        conexion = sqlite3.connect("lore.db")
        cursor = conexion.cursor()
        morfologia = {}
        
        cursor.execute("SELECT id, nombre FROM regiones")
        regiones = cursor.fetchall()
        
        for region_id, nombre_region in regiones:
            morfologia[nombre_region] = {"prefijos": [], "raices": [], "sufijos": []}
            cursor.execute("SELECT tipo, valor FROM morfemas WHERE region_id = ?", (region_id,))
            morfemas = cursor.fetchall()
            
            for tipo, valor in morfemas:
                morfologia[nombre_region][tipo].append(valor)
                
        conexion.close()
        return morfologia
    except sqlite3.OperationalError:
        return {}


def obtener_facciones_region(nombre_region):
    try:
        conexion = sqlite3.connect("lore.db")
        cursor = conexion.cursor()
        cursor.execute("""
            SELECT f.tipo, f.nombre 
            FROM facciones f
            JOIN regiones r ON f.region_id = r.id
            WHERE r.nombre = ?
        """, (nombre_region,))
        facciones = cursor.fetchall()
        conexion.close()
        return facciones
    except sqlite3.Error:
        return []


