        self.stack_formularios.setCurrentIndex(index)

    def actualizar_combos(self):
        """Llena los selectores iniciales y de filtrado desde la base de datos."""
        # Bloqueamos señales temporalmente para evitar ejecuciones en cascada vacías
        self.combo_edit_region.blockSignals(True)
        self.combo_filtro_reg_f.blockSignals(True)
        self.combo_filtro_reg_m.blockSignals(True)

        self.combo_edit_region.clear()
        self.combo_filtro_reg_f.clear()
        self.combo_filtro_reg_m.clear()

        try:
            conexion = sqlite3.connect("lore.db")
            cursor = conexion.cursor()
            cursor.execute("SELECT id, nombre FROM regiones")
            regiones = cursor.fetchall()
            conexion.close()

            for r_id, r_nombre in regiones:
                self.combo_edit_region.addItem(r_nombre, userData=r_id)
                self.combo_filtro_reg_f.addItem(r_nombre, userData=r_id)
                self.combo_filtro_reg_m.addItem(r_nombre, userData=r_id)
        except sqlite3.Error:
            pass

        self.combo_edit_region.blockSignals(False)
        self.combo_filtro_reg_f.blockSignals(False)
        self.combo_filtro_reg_m.blockSignals(False)

        # Forzar recarga manual ordenada
        self.preparar_edicion_region()
        self.cargar_facciones_por_filtro()
        self.cargar_morfemas_por_filtro()

    # --- FLUJO REGIONES ---
    def preparar_edicion_region(self):
        self.input_edit_region.setText(self.combo_edit_region.currentText())

    def actualizar_region(self):
        region_id = self.combo_edit_region.currentData()
        nuevo_nombre = self.input_edit_region.text().strip()
        if not region_id or not nuevo_nombre: return

        try:
            conexion = sqlite3.connect("lore.db")
            cursor = conexion.cursor()
            cursor.execute("UPDATE regiones SET nombre = ? WHERE id = ?", (nuevo_nombre, region_id))
            conexion.commit()
            conexion.close()
            QMessageBox.information(self, "Éxito", "Nombre de la región modificado con éxito.")
            self.callback_sincronizar()
        except sqlite3.Error as e:
            QMessageBox.warning(self, "Error", "La región ya existe o es inválida.")

    def eliminar_region(self):
        region_id = self.combo_edit_region.currentData()
        if not region_id: return
        
        box = QMessageBox.question(self, "Confirmar", 
                                   "⚠️ ¿Seguro que deseas eliminar esta región?\n"
                                   "Esto borrará de forma PERMANENTE todos sus reinos, tribus y morfemas asociados.",
                                   QMessageBox.Yes | QMessageBox.No)
        if box == QMessageBox.Yes:
            conexion = sqlite3.connect("lore.db")
            cursor = conexion.cursor()
            cursor.execute("DELETE FROM morfemas WHERE region_id = ?", (region_id,))
            cursor.execute("DELETE FROM facciones WHERE region_id = ?", (region_id,))
            cursor.execute("DELETE FROM regiones WHERE id = ?", (region_id,))
            conexion.commit()
            conexion.close()
            self.callback_sincronizar()

    # --- FLUJO FACCIONES ---
    def cargar_facciones_por_filtro(self):
        self.combo_edit_faccion.blockSignals(True)
        self.combo_edit_faccion.clear()
        region_id = self.combo_filtro_reg_f.currentData()
        
        if region_id:
            conexion = sqlite3.connect("lore.db")
            cursor = conexion.cursor()
            cursor.execute("SELECT id, nombre, tipo FROM facciones WHERE region_id = ?", (region_id,))
            facciones = cursor.fetchall()
            conexion.close()
            for f_id, f_nombre, f_tipo in facciones:
                self.combo_edit_faccion.addItem(f"[{f_tipo}] {f_nombre}", userData=f_id)
                
        self.combo_edit_faccion.blockSignals(False)
        self.preparar_edicion_faccion()

    def preparar_edicion_faccion(self):
        faccion_id = self.combo_edit_faccion.currentData()
        if not faccion_id:
            self.input_edit_faccion.clear()
            return
        conexion = sqlite3.connect("lore.db")
        cursor = conexion.cursor()
        cursor.execute("SELECT nombre, tipo FROM facciones WHERE id = ?", (faccion_id,))
        res = cursor.fetchone()
        conexion.close()
        if res:
            self.input_edit_faccion.setText(res[0])
            self.combo_edit_tipo_f.setCurrentText(res[1])

    def actualizar_faccion(self):
        faccion_id = self.combo_edit_faccion.currentData()
        nuevo_nombre = self.input_edit_faccion.text().strip()
        nuevo_tipo = self.combo_edit_tipo_f.currentText()
        if not faccion_id or not nuevo_nombre: return

        conexion = sqlite3.connect("lore.db")
        cursor = conexion.cursor()
        cursor.execute("UPDATE facciones SET nombre = ?, tipo = ? WHERE id = ?", (nuevo_nombre, nuevo_tipo, faccion_id))
        conexion.commit()
        conexion.close()
        QMessageBox.information(self, "Éxito", "Facción actualizada correctamente.")
        self.callback_sincronizar()

    def eliminar_faccion(self):
        faccion_id = self.combo_edit_faccion.currentData()
        if not faccion_id: return
        conexion = sqlite3.connect("lore.db")
        cursor = conexion.cursor()
        cursor.execute("DELETE FROM facciones WHERE id = ?", (faccion_id,))
        conexion.commit()
        conexion.close()
        self.callback_sincronizar()

    # --- FLUJO MORFEMAS ---
    def cargar_morfemas_por_filtro(self):
        self.combo_edit_morfema.blockSignals(True)
        self.combo_edit_morfema.clear()
        region_id = self.combo_filtro_reg_m.currentData()
        tipo = self.combo_filtro_tipo_m.currentText()
        
        if region_id and tipo:
            conexion = sqlite3.connect("lore.db")
            cursor = conexion.cursor()
            cursor.execute("SELECT id, valor FROM morfemas WHERE region_id = ? AND tipo = ?", (region_id, tipo))
            morfemas = cursor.fetchall()
            conexion.close()
            for m_id, m_valor in morfemas:
                self.combo_edit_morfema.addItem(m_valor, userData=m_id)
                
        self.combo_edit_morfema.blockSignals(False)
        self.preparar_edicion_morfema()

    def preparar_edicion_morfema(self):
        morfema_id = self.combo_edit_morfema.currentData()
        if not morfema_id:
            self.input_edit_morfema.clear()
            return
        conexion = sqlite3.connect("lore.db")
        cursor = conexion.cursor()
        cursor.execute("SELECT valor FROM morfemas WHERE id = ?", (morfema_id,))
        res = cursor.fetchone()
        conexion.close()
        if res:
            self.input_edit_morfema.setText(res[0])

    def actualizar_morfema(self):
        morfema_id = self.combo_edit_morfema.currentData()
        nuevo_valor = self.input_edit_morfema.text().strip().lower()
        if not morfema_id or not nuevo_valor: return

        conexion = sqlite3.connect("lore.db")
        cursor = conexion.cursor()
        cursor.execute("UPDATE morfemas SET valor = ? WHERE id = ?", (nuevo_valor, morfema_id))
        conexion.commit()
        conexion.close()
        QMessageBox.information(self, "Éxito", "Morfema lingüístico actualizado.")
        self.callback_sincronizar()

    def eliminar_morfema(self):
        morfema_id = self.combo_edit_morfema.currentData()
        if not morfema_id: return
        conexion = sqlite3.connect("lore.db")
        cursor = conexion.cursor()
        cursor.execute("DELETE FROM morfemas WHERE id = ?", (morfema_id,))
        conexion.commit()
        conexion.close()
        self.callback_sincronizar()


