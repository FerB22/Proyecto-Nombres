    def generar_nombre(self):
        region = self.combo_region.currentText()
        reglas = morfologia_universo[region]
        cantidad_silabas = int(self.combo_silabas.currentText())

        prefijo = random.choice(reglas["prefijos"])
        sufijo = random.choice(reglas["sufijos"])

        if cantidad_silabas == 2:
            nombre_crudo = f"{prefijo}{sufijo}"
        elif cantidad_silabas == 3:
            raiz = random.choice(reglas["raices"])
            nombre_crudo = f"{prefijo}{raiz}{sufijo}"
        else:
            raiz1 = random.choice(reglas["raices"])
            raiz2 = random.choice(reglas["raices"])
            nombre_crudo = f"{prefijo}{raiz1}{raiz2}{sufijo}"

        nombre_generado = nombre_crudo.lower().capitalize()
        self.etiqueta_resultado.setText(f"✨ {nombre_generado} ✨")

        historial_nombres[region].append(nombre_generado)

        texto = []
        for reg, nombres in historial_nombres.items():
            if nombres:
                texto.append(f"--- {reg} ---")
                for n in nombres:
                    texto.append(f"• {n}")
                texto.append("")

        self.texto_historial.setPlainText("\n".join(texto))

    def restaurar_geometria(self):
        geometry = self.settings.value("geometry")
        if geometry:
            self.restoreGeometry(geometry)

    def closeEvent(self, event):
        self.settings.setValue("geometry", self.saveGeometry())
        super().closeEvent(event)


