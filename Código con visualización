# --- NUEVA FUNCIÓN PARA CARGAR DATOS DESDE SQL ---
def cargar_datos_sql():
    try:
        conexion = sqlite3.connect("lore.db")
        cursor = conexion.cursor()
        
        morfologia = {}
        
        # Obtenemos todas las regiones
        cursor.execute("SELECT id, nombre FROM regiones")
        regiones = cursor.fetchall()
        
        for region_id, nombre_region in regiones:
            morfologia[nombre_region] = {"prefijos": [], "raices": [], "sufijos": []}
            
            # Obtenemos los morfemas de esta región
            cursor.execute("SELECT tipo, valor FROM morfemas WHERE region_id = ?", (region_id,))
            morfemas = cursor.fetchall()
            
            for tipo, valor in morfemas:
                morfologia[nombre_region][tipo].append(valor)
                
        conexion.close()
        
        # Si la base de datos está vacía, avisamos para evitar errores
        if not morfologia:
            print("⚠️ La base de datos está vacía o no tiene el formato correcto.")
            sys.exit(1)
            
        return morfologia
        
    except sqlite3.OperationalError:
        print("⚠️ Error: No se encontró la base de datos 'lore.db'.")
        print("Por favor, ejecuta primero el script que crea la base de datos.")
        sys.exit(1)

# 1. Cargamos la base de datos a la memoria de la app
morfologia_universo = cargar_datos_sql()

# 2. Generamos el historial dinámicamente basado en las regiones que existan en la BD
historial_nombres = {region: [] for region in morfologia_universo.keys()}


